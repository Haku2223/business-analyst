ANTHROPIC_API_KEY=sk-ant-...          # Claude Haiku API key (Phase 2b). Never expose to frontend.
TEAM_PASSWORD_HASH=                  # bcrypt hash of shared team password (min 16 chars)
JWT_SECRET=                          # Random 32-byte hex string (run: python -c "import secrets; print(secrets.token_hex(32))")
DATABASE_URL=                        # PostgreSQL connection string. Omit for SQLite auto-fallback.
PORT=8000                            # Server port
